  "credit_valuation_rules": {
    "source": "UCT Humanities Handbook 2026, Abbreviations and Definitions",
    "one_nqf_credit_equals_notional_hours": 10,
    "bachelors_3_year_minimum_nqf_credits": 360,
    "bachelors_3_year_minimum_level_7_credits": 120,
    "semester_course_equivalents": {
      "F": 1,
      "S": 1,
      "FS": 1,
      "SF": 1,
      "H": 0.5,
      "W": 2,
      "P": 1,
      "U": 1,
      "L": 1,
      "Z": 1
    },
    "notes": [
      "F and S are single-semester courses.",
      "FS and SF codes usually indicate that the same semester course may be offered in either semester.",
      "W is a whole-year course and counts as two semester courses.",
      "H is a half-course taught throughout the year and counts as half a semester course.",
      "P, U, L and Z are non-standard period courses; this prototype counts them as one semester-course equivalent unless a departmental rule says otherwise."
    ]
  },
  "degree_classification_rules": {
    "minimum_majors": 2,
    "at_least_one_humanities_major": true,
    "humanities_includes_school_of_economics": true,
    "if_both_majors_are_ba": {
      "degree": "Bachelor of Arts",
      "qualification_code": "HB003"
    },
    "if_both_majors_are_bsocsc": {
      "degree": "Bachelor of Social Science",
      "qualification_code": "HB001"
    },
    "if_one_ba_and_one_bsocsc": {
      "degree": "Bachelor of Arts or Bachelor of Social Science",
      "student_may_choose": true
    },
    "if_one_major_is_non_humanities": {
      "degree": "Degree follows the Humanities Faculty major",
      "note": "Student must still take at least one major offered by Humanities."
    }
  },
